# ═══════════════════════════════════════════════
# Al-Fateeh - Production Environment Variables
# انسخ هذا الملف إلى .env على الاستضافة وعدّل القيم
# ═══════════════════════════════════════════════

# Application
APP_NAME="Al-Fateeh"
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_YOUR_KEY
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Port (المنفذ الذي سيعمل عليه التطبيق على الاستضافة)
APP_PORT=8000

# ─────────────────────────────────────────
# Database (Neon PostgreSQL)
# ─────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=ep-hidden-mouse-av06r3w9.c-11.us-east-1.aws.neon.tech
DB_PORT=5432
DB_DATABASE=neondb
DB_USERNAME=neondb_owner
DB_PASSWORD=REPLACE_WITH_REAL_PASSWORD

# ─────────────────────────────────────────
# Session & Cache
# ─────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# ─────────────────────────────────────────
# Mail
# ─────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=REPLACE_WITH_MAIL_USERNAME
MAIL_PASSWORD=REPLACE_WITH_MAIL_PASSWORD
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="Al-Fateeh"

# ─────────────────────────────────────────
# ImageKit Config
# ─────────────────────────────────────────
PRIVATE_KEY="REPLACE_WITH_IMAGEKIT_PRIVATE_KEY"
URL_ENDPOINT="REPLACE_WITH_IMAGEKIT_URL_ENDPOINT"
KITIMAGE_UPLOAD_URL="https://upload.imagekit.io/api/v1/files/upload"
